
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Abubakr uchun maxsus: Hamma foydalanuvchilar o'z ma'lumotlarini o'qishi va yozishi mumkin.
    // Anonymous auth yoqilmagan bo'lsa ham ishlaydi.
    match /users/{userId}/{document=**} {
      allow read, write: if true;
    }
  }
}
